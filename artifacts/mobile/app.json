{
  "expo": {
    "name": "Swift Tow",
    "slug": "swift-tow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swifttow",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#34495E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swifttow.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Swift Tow needs your location to find nearby tow truck drivers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Swift Tow uses your location to match you with drivers and track your tow request."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#34495E"
      },
      "package": "com.swifttow.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "swifttow.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://swifttow.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Swift Tow needs your location to find drivers near you.",
          "locationAlwaysAndWhenInUsePermission": "Swift Tow uses your location to match you with a driver and show your real-time position during towing."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "swift-tow-app"
      }
    }
  }
}
